# ==================== RAG 模型服务 API 密钥 ====================

# BGE-large-zh 嵌入模型 API 密钥 (ModelScope)
RAG_EMBEDDING_API_KEY=your-model-scope-api-key-here

# BGE-reranker-v2-m3 重排序模型 API 密钥 (ModelScope)
